# ---------------------------------------------------------------------------
# Contact form email delivery (SendGrid)
# Copy this file to `.env.local` and fill in real values. Never commit .env.local.
# ---------------------------------------------------------------------------

# API key from https://app.sendgrid.com/settings/api_keys (needs "Mail Send" permission)
SENDGRID_API_KEY=

# Inbox that receives contact-form submissions (where your team reads them).
# Optional — defaults to the site's contact email if left blank.
CONTACT_TO_EMAIL=

# The "from" address. MUST be a verified Single Sender or authenticated domain
# in SendGrid, or the send will be rejected.
# Set up at https://app.sendgrid.com/settings/sender_auth
CONTACT_FROM_EMAIL=
